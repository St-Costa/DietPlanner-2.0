{
  "name": "dietplanner",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:frontend\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:frontend": "cd frontend && bun run dev",
    "build": "cd frontend && bun run build",
    "start": "bun server/index.ts",
    "check": "cd frontend && bun run check"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "node-html-parser": "^7.0.2"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
